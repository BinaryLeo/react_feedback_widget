---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Feedback Widget Demo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Feedback Widget - Get feedback from your customers" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen font-sans">
    <slot />
  </body>
</html>
