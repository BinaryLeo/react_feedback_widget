# ==========================================
# FEEDBACK WIDGET WEB - LOCAL DEVELOPMENT
# ==========================================
# Copy this file to .env
# ⚠️  IMPORTANT: Frontend .env files are PUBLIC - never put secrets here!

# ==========================================
# API CONFIGURATION - REQUIRED
# ==========================================
PUBLIC_API_URL=http://localhost:3333

# ==========================================
# WIDGET UI CONFIGURATION (Optional)
# ==========================================
# Default language: en, es, pt-BR, zh
PUBLIC_DEFAULT_LANGUAGE=en

# Widget position: bottom-right, bottom-left, top-right, top-left
PUBLIC_WIDGET_POSITION=bottom-right

# Brand color (hex without #)
PUBLIC_WIDGET_COLOR=8B5CF6
