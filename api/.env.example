# ==========================================
# FEEDBACK WIDGET API - LOCAL DEVELOPMENT
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE (PostgreSQL) - REQUIRED
# ==========================================
# Using Docker: docker run -d --name feedback-db -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=feedback_widget -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/feedback_widget?schema=public"

# ==========================================
# SECURITY - REQUIRED
# ==========================================
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here-change-this-in-production

# ==========================================
# API SERVER - REQUIRED
# ==========================================
PORT=3333
NODE_ENV=development

# CORS Origins (comma-separated for multiple domains)
CORS_ORIGIN=http://localhost:4321,http://localhost:3000

# ==========================================
# AI PROVIDERS (OPTIONAL - Widget works great without AI!)
# ==========================================
# AI keys are NEVER stored on the server in production mode
# They are encrypted in the user's browser localStorage

# For local development, you can configure AI here:
# AI_PROVIDER=ANTHROPIC
# AI_API_KEY=sk-your-key-here
# AI_MODEL=claude-sonnet-4-20250514

# Or disable AI (default):
AI_PROVIDER=NONE

# ==========================================
# EMAIL / SMTP (OPTIONAL - for notifications)
# ==========================================
# For development, use Mailtrap: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password

# Enable/disable email notifications
ENABLE_EMAIL_NOTIFICATIONS=false
ADMIN_EMAIL=admin@example.com
