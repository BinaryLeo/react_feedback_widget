{
  "name": "react-feedback-widget-api",
  "version": "2.0.0",
  "description": "Feedback Widget API - Modern Version",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:bun": "bun --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:bun": "bun dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:bun": "bun prisma/seed.ts"
  },
  "keywords": [
    "feedback",
    "api",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.0.0",
    "@scalar/express-api-reference": "^0.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "jest": "^29.7.0",
    "prisma": "7.0.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
